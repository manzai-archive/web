---
import { getEntry } from 'astro:content';

const { entry } = Astro.props;
const base = import.meta.env.BASE_URL;
const perfRef = entry.data.performers[0];
const perf = perfRef ? await getEntry(perfRef) : null;
const groupName = perf?.data.display_name ?? (typeof perfRef === 'string' ? perfRef : perfRef?.id) ?? 'Unknown';
const lang = perf?.data.language ?? entry.data.language;

const FORM_LABEL: Record<string, string> = {
  manzai: '漫才',
  xiangsheng: '相声',
  standup: '脱口秀',
  sketch: 'コント / 小品',
  rakugo: '落語',
  other: '其他',
};
const formLabel = FORM_LABEL[entry.data.form] ?? entry.data.form;
---
<a
  href={`${base}manzai/${entry.id}/`}
  class="group block py-5 border-b transition-colors"
  style="border-color: var(--color-rule)"
>
  <div class="flex items-baseline gap-3 text-[12px] mb-1.5" style="color: var(--color-ink-faint)">
    <span class="px-1.5 py-0.5 border rounded text-[11px] tracking-wide" style="border-color: var(--color-rule); color: var(--color-ink-soft)">{formLabel}</span>
    <span lang={lang} class="text-[var(--color-ink-soft)]">{groupName}</span>
    {entry.data.source.uploaded_at && (
      <span class="ml-auto tabular-nums">{entry.data.source.uploaded_at}</span>
    )}
  </div>
  <div class="font-mincho text-lg leading-snug group-hover:text-[var(--color-accent)] transition-colors" lang={entry.data.language}>
    {entry.data.title}
  </div>
  {(entry.data.tags.length > 0 || entry.data.status === 'draft') && (
    <div class="flex gap-2 text-[11px] mt-2" style="color: var(--color-ink-faint)">
      {entry.data.tags.map((t: string) => <span>#{t}</span>)}
      {entry.data.status === 'draft' && (
        <span class="ml-auto" style="color: var(--color-warm)">未校对</span>
      )}
    </div>
  )}
</a>
