---
const { speaker, time, text, idx } = Astro.props;
---
<div class="script-line flex gap-3 py-1.5" data-speaker-idx={idx % 2}>
  <span class="speaker font-semibold w-24 shrink-0 text-right">{speaker}</span>
  <span class="text-xs text-neutral-400 w-16 shrink-0 tabular-nums pt-1">{time}</span>
  <span class="flex-1">{text}</span>
</div>
