---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import EntryCard from '../components/EntryCard.astro';

const all = await getCollection('manzai');
const recent = all
  .sort((a, b) =>
    (b.data.source.uploaded_at ?? '').localeCompare(a.data.source.uploaded_at ?? '')
  )
  .slice(0, 12);
---
<Base title="漫才档案">
  <section class="mb-16">
    <h1 class="text-4xl mb-4 leading-tight">漫才档案</h1>
    <p class="text-[14px] leading-relaxed max-w-prose" style="color: var(--color-ink-soft)">
      带说话人标注的漫才剧本语料库 · 面向语言学习与喜剧研究 · 非营利
    </p>
  </section>

  <section>
    <div class="flex items-baseline justify-between mb-4">
      <h2 class="text-base tracking-wide" style="color: var(--color-ink-soft)">最近的剧本</h2>
      <a href={`${import.meta.env.BASE_URL}manzai/`} class="text-[12px] underline" style="color: var(--color-ink-faint)">全部 →</a>
    </div>

    {recent.length > 0 ? (
      <div class="border-t" style="border-color: var(--color-rule)">
        {recent.map((entry) => <EntryCard entry={entry} />)}
      </div>
    ) : (
      <div class="text-[13px] py-12 text-center border-t border-dashed rounded" style="border-color: var(--color-rule); color: var(--color-ink-faint)">
        还没有剧本。
      </div>
    )}
  </section>
</Base>
