---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import EntryCard from '../components/EntryCard.astro';

const all = await getCollection('manzai');
const recent = all
  .sort((a, b) =>
    (b.data.source.uploaded_at ?? '').localeCompare(a.data.source.uploaded_at ?? '')
  )
  .slice(0, 12);
---
<Base title="漫才アーカイブ">
  <h1 class="text-2xl font-bold mb-2">漫才アーカイブ</h1>
  <p class="text-neutral-600 mb-8 text-sm">
    話者ラベル付き漫才台本コーパス · 语学学习与喜剧研究用 · 非营利
  </p>

  <h2 class="text-lg font-semibold mb-4">最近的剧本</h2>
  {recent.length > 0 ? (
    <div class="grid sm:grid-cols-2 gap-3">
      {recent.map((entry) => <EntryCard entry={entry} />)}
    </div>
  ) : (
    <div class="text-neutral-500 text-sm border border-dashed border-neutral-300 rounded p-6 text-center">
      还没有剧本。在 <code class="bg-neutral-100 px-1 rounded">pipeline</code> 仓库运行
      <code class="bg-neutral-100 px-1 rounded">python -m pipeline ingest &lt;url&gt;</code> 抓取一份。
    </div>
  )}
</Base>
