---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EntryCard from '../../components/EntryCard.astro';

const all = (await getCollection('manzai')).sort((a, b) =>
  (b.data.source.uploaded_at ?? '').localeCompare(a.data.source.uploaded_at ?? '')
);
---
<Base title="所有剧本 · 漫才档案">
  <h1 class="text-2xl font-bold mb-6">所有剧本 ({all.length})</h1>
  <div class="grid sm:grid-cols-2 gap-3">
    {all.map((entry) => <EntryCard entry={entry} />)}
  </div>
</Base>
