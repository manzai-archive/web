---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import EntryCard from '../../components/EntryCard.astro';

const all = (await getCollection('manzai')).sort((a, b) =>
  (b.data.source.uploaded_at ?? '').localeCompare(a.data.source.uploaded_at ?? '')
);
---
<Base title="所有剧本 · 漫才档案">
  <section class="mb-10">
    <h1 class="text-3xl mb-2">所有剧本</h1>
    <p class="text-[13px]" style="color: var(--color-ink-faint)">共 {all.length} 件作品</p>
  </section>

  <div class="border-t" style="border-color: var(--color-rule)">
    {all.map((entry) => <EntryCard entry={entry} />)}
  </div>
</Base>
