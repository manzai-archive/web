---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SpeakerLine from '../../components/SpeakerLine.astro';

export async function getStaticPaths() {
  const entries = await getCollection('manzai');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;

const lineRegex = /\*\*(.+?)\*\*\s*\[(\d{2}:\d{2}:\d{2})\]\s*(.+)/;
const speakerMap: Record<string, string> = entry.data.speakers ?? {};
const sourceLang = entry.data.language;
const translations: Record<string, string[]> = entry.data.translations ?? {};

const bodyMatches = entry.body
  .split('\n')
  .map((l: string) => l.match(lineRegex))
  .filter((m: RegExpMatchArray | null): m is RegExpMatchArray => m !== null);

const validTranslations: Record<string, string[]> = {};
for (const [lang, arr] of Object.entries(translations)) {
  if (Array.isArray(arr) && arr.length === bodyMatches.length) {
    validTranslations[lang] = arr;
  }
}

const availableLangs = [sourceLang, ...Object.keys(validTranslations).filter((l) => l !== sourceLang)];
const defaultLang = availableLangs.includes('zh') ? 'zh' : sourceLang;

// Comedy form & per-performance roles
const FORM_LABEL: Record<string, string> = {
  manzai: '漫才',
  xiangsheng: '相声',
  standup: '脱口秀',
  sketch: 'コント / 小品',
  rakugo: '落語',
  other: '其他',
};
const formLabel = FORM_LABEL[entry.data.form] ?? entry.data.form;
const roles: Record<string, string> = entry.data.roles ?? {};
const speakerWithRole = (name: string) => {
  const r = roles[name];
  return r ? `${name} (${r})` : name;
};

const lines = bodyMatches.map((m, i) => {
  const texts: Record<string, string> = { [sourceLang]: m[3] };
  for (const [lang, arr] of Object.entries(validTranslations)) {
    texts[lang] = arr[i];
  }
  const rawSpeaker = speakerMap[m[1]] ?? m[1];
  return {
    speaker: rawSpeaker,  // role displayed once in the cast row above
    time: m[2],
    texts,
  };
});

const speakerOrder = Array.from(new Set(lines.map((l) => l.speaker)));

const langLabel: Record<string, string> = { zh: '中', ja: '原文(日)', en: 'EN' };

// Resolve performer reference
const perfRef = entry.data.performers[0];
const perf = perfRef ? await getEntry(perfRef) : null;
const perfName = perf?.data.display_name ?? (typeof perfRef === 'string' ? perfRef : perfRef?.id) ?? 'Unknown';
const perfLang = perf?.data.language ?? sourceLang;
---
<Base title={`${entry.data.title} · 漫才档案`}>
  <article>
    <div class="mb-6">
      <div class="text-xs text-neutral-500 mb-1" lang={perfLang}>
        {perf ? (
          <a class="hover:underline" href={`${import.meta.env.BASE_URL}manzai/?group=${perfRef.id ?? perfRef}`}>{perfName}</a>
        ) : perfName}
      </div>
      <h1 class="text-2xl font-bold mb-2" lang={sourceLang}>{entry.data.title}</h1>
      <div class="flex gap-1.5 text-xs flex-wrap mb-2">
        <span class="px-2 py-0.5 bg-blue-50 text-blue-700 rounded font-medium">{formLabel}</span>
        {entry.data.tags.map((t: string) => (
          <span class="px-2 py-0.5 bg-neutral-100 rounded">{t}</span>
        ))}
        {entry.data.status === 'draft' && (
          <span class="px-2 py-0.5 bg-amber-100 text-amber-700 rounded">draft (未校对)</span>
        )}
      </div>
      {Object.keys(roles).length > 0 && (
        <div class="text-sm text-neutral-700 mb-3 flex gap-3 flex-wrap" lang={perfLang}>
          <span class="text-neutral-500">出演：</span>
          {Object.entries(roles).map(([name, role]: [string, string]) => (
            <span><b>{name}</b> <span class="text-neutral-500">({role})</span></span>
          ))}
        </div>
      )}
      <div class="text-sm">
        <a class="underline text-blue-700" href={entry.data.source.url} target="_blank" rel="noopener">
          原视频 ({entry.data.source.platform})
        </a>
        {entry.data.source.uploader && (
          <span class="text-neutral-500"> · {entry.data.source.uploader}</span>
        )}
        {entry.data.source.uploaded_at && (
          <span class="text-neutral-500"> · {entry.data.source.uploaded_at}</span>
        )}
      </div>
    </div>

    <div class="script-container bg-white border border-neutral-200 rounded-md p-5" data-display={defaultLang} data-pagefind-body>
      {availableLangs.length > 1 && (
        <div class="lang-toggle flex gap-1 mb-4 text-sm items-center">
          <span class="text-xs text-neutral-500 mr-2">显示</span>
          {availableLangs.map((lang) => (
            <button type="button" class="lang-btn px-3 py-1 rounded border border-neutral-300 hover:border-neutral-500" data-set-lang={lang}>
              {langLabel[lang] ?? lang}
            </button>
          ))}
          <button type="button" class="lang-btn px-3 py-1 rounded border border-neutral-300 hover:border-neutral-500" data-set-lang="both">双语</button>
        </div>
      )}

      <div class="lines">
        {lines.map((l) => (
          <SpeakerLine
            speaker={l.speaker}
            time={l.time}
            texts={l.texts}
            idx={speakerOrder.indexOf(l.speaker)}
          />
        ))}
      </div>
    </div>

    {entry.data.sensitivity === 'high' && (
      <p class="mt-4 text-xs text-neutral-500">
        本作品来源于版权敏感的赛事/电视节目。本站仅保留文字片段供研究学习，请通过原视频链接观看完整内容支持创作者。
      </p>
    )}

    {entry.data.ingestion && (
      <details class="mt-6 text-xs text-neutral-500">
        <summary class="cursor-pointer">溯源信息</summary>
        <dl class="mt-2 grid grid-cols-[auto_1fr] gap-x-3 gap-y-1">
          {entry.data.source.fetched_at && <><dt>抓取时间</dt><dd>{entry.data.source.fetched_at}</dd></>}
          {entry.data.source.fetched_with && <><dt>抓取工具</dt><dd>{entry.data.source.fetched_with}</dd></>}
          {entry.data.ingestion.pipeline_version && <><dt>Pipeline 版本</dt><dd>{entry.data.ingestion.pipeline_version}</dd></>}
          {entry.data.ingestion.asr && <><dt>ASR</dt><dd>{entry.data.ingestion.asr.backend} / {entry.data.ingestion.asr.model}</dd></>}
          {entry.data.ingestion.asr?.detected_language && <><dt>检测语言</dt><dd>{entry.data.ingestion.asr.detected_language}</dd></>}
          {entry.data.ingestion.asr?.word_count && <><dt>词数</dt><dd>{entry.data.ingestion.asr.word_count}</dd></>}
          {entry.data.ingestion.diarization && <><dt>分离</dt><dd>{entry.data.ingestion.diarization.model}（{entry.data.ingestion.diarization.num_speakers}人，{entry.data.ingestion.diarization.turn_count} 轮）</dd></>}
          {entry.data.contributed_by && <><dt>贡献者</dt><dd>{entry.data.contributed_by}</dd></>}
        </dl>
      </details>
    )}
  </article>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const container = btn.closest<HTMLElement>('.script-container');
        const lang = btn.dataset.setLang;
        if (container && lang) container.dataset.display = lang;
      });
    });
  </script>
</Base>
