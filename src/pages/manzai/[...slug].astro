---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SpeakerLine from '../../components/SpeakerLine.astro';

export async function getStaticPaths() {
  const entries = await getCollection('manzai');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;

const speakerMap: Record<string, string> = entry.data.speakers ?? {};
const sourceLang = entry.data.language;

const dialogueEntry = await getEntry('dialogues', entry.id);

type Utterance = {
  id: string;
  speaker: string;
  time: string;
  texts: Record<string, string>;
};
let lines: Utterance[] = [];
type RawUtterance = { id: string; t: string; speaker: string; text: string; translations?: Record<string, string> };
let rawUtterances: RawUtterance[] = [];

if (dialogueEntry) {
  rawUtterances = dialogueEntry.data.utterances.map((u, i) => ({
    id: u.id || `u${i + 1}`,
    t: u.t,
    speaker: u.speaker,
    text: u.text,
    translations: u.translations,
  }));
  for (const u of rawUtterances) {
    const texts: Record<string, string> = { [sourceLang]: u.text };
    for (const [lang, t] of Object.entries(u.translations ?? {})) {
      if (typeof t === 'string') texts[lang] = t;
    }
    lines.push({
      id: u.id,
      speaker: speakerMap[u.speaker] ?? u.speaker,
      time: u.t,
      texts,
    });
  }
} else {
  // Legacy in-body parsing (pre-Plan-C entries)
  const lineRegex = /\*\*(.+?)\*\*\s*\[(\d{2}:\d{2}:\d{2})\]\s*(.+)/;
  const bodyMatches = entry.body
    .split('\n')
    .map((l: string) => l.match(lineRegex))
    .filter((m: RegExpMatchArray | null): m is RegExpMatchArray => m !== null);
  rawUtterances = bodyMatches.map((m, i) => ({
    id: `u${i + 1}`,
    t: m[2],
    speaker: m[1],
    text: m[3],
  }));
  lines = bodyMatches.map((m, i) => ({
    id: `u${i + 1}`,
    speaker: speakerMap[m[1]] ?? m[1],
    time: m[2],
    texts: { [sourceLang]: m[3] },
  }));
}

const availableLangs = Array.from(
  new Set(lines.flatMap((l) => Object.keys(l.texts)))
).sort((a, b) => (a === sourceLang ? -1 : b === sourceLang ? 1 : 0));
const defaultLang = availableLangs.includes('zh') ? 'zh' : sourceLang;

const FORM_LABEL: Record<string, string> = {
  manzai: '漫才',
  xiangsheng: '相声',
  standup: '脱口秀',
  sketch: 'コント / 小品',
  rakugo: '落語',
  other: '其他',
};
const formLabel = FORM_LABEL[entry.data.form] ?? entry.data.form;
const roles: Record<string, string> = entry.data.roles ?? {};

const speakerOrder = Array.from(new Set(lines.map((l) => l.speaker)));

const langLabel: Record<string, string> = { zh: '中', ja: '日', en: 'EN', auto: '原文' };

const perfRef = entry.data.performers[0];
const perf = perfRef ? await getEntry(perfRef) : null;
const perfName = perf?.data.display_name ?? (typeof perfRef === 'string' ? perfRef : perfRef?.id) ?? 'Unknown';
const perfLang = perf?.data.language ?? sourceLang;

// Speaker dropdown options for the editor: union of canonical members
// (from the performer registry) and any speaker labels seen in the
// dialogue. Keeps weird auto-generated labels usable as a fallback.
const memberNames = (perf?.data.members ?? []).map((m: { name: string }) => m.name);
const speakerOptions = Array.from(new Set([
  ...memberNames,
  ...rawUtterances.map((u) => u.speaker),
])).filter(Boolean);

const isDev = import.meta.env.DEV;
const dialoguePath = `src/content/dialogues/${entry.id}.yaml`;
const entryPath = `src/content/manzai/${entry.id}.md`;
const githubBase = 'https://github.com/manzai-archive/web';
const githubEditDialogue = `${githubBase}/edit/main/${dialoguePath}`;
const githubEditEntry = `${githubBase}/edit/main/${entryPath}`;

const editorBootstrap = {
  slug: entry.id,
  utterances: rawUtterances,
  speakerOptions,
  sourceLang,
  dialoguePath,
  entryPath,
  githubEditDialogue,
  githubEditEntry,
};
---
<Base title={`${entry.data.title} · 喜剧档案`}>
  <article>
    <header class="mb-10">
      <div class="flex items-baseline gap-3 text-[12px] mb-3" style="color: var(--color-ink-faint)">
        <span class="px-1.5 py-0.5 border rounded text-[11px] tracking-wide" style="border-color: var(--color-rule); color: var(--color-ink-soft)">{formLabel}</span>
        <span lang={perfLang} class="text-[var(--color-ink-soft)]">{perfName}</span>
        {entry.data.source.uploaded_at && (
          <span class="ml-auto tabular-nums">{entry.data.source.uploaded_at}</span>
        )}
      </div>

      <h1 class="text-3xl leading-tight mb-5" lang={sourceLang}>{entry.data.title}</h1>

      {Object.keys(roles).length > 0 && (
        <div class="text-[13px] mb-3" lang={perfLang}>
          {Object.entries(roles).map(([name, role]: [string, string], i: number) => (
            <>
              {i > 0 && <span class="mx-2" style="color: var(--color-ink-faint)">·</span>}
              <span class="font-medium">{name}</span>
              <span class="ml-1.5" style="color: var(--color-ink-faint)">{role}</span>
            </>
          ))}
        </div>
      )}

      <div class="flex flex-wrap items-center gap-3 text-[12px]" style="color: var(--color-ink-faint)">
        <a class="underline hover:text-[var(--color-ink-soft)]" href={entry.data.source.url} target="_blank" rel="noopener">
          原视频 ({entry.data.source.platform})
        </a>
        {entry.data.source.uploader && <span>{entry.data.source.uploader}</span>}
        {entry.data.tags.map((t: string) => <span>#{t}</span>)}
        {entry.data.status === 'draft' && <span style="color: var(--color-warm)">未校对</span>}
        <a class="ml-auto underline hover:text-[var(--color-ink-soft)]" href={githubEditDialogue} target="_blank" rel="noopener">
          在 GitHub 上编辑
        </a>
        {isDev && (
          <button id="enter-edit" type="button" class="px-2 py-0.5 border rounded text-[11px]" style="border-color: var(--color-rule); color: var(--color-ink-soft)">
            编辑（本地）
          </button>
        )}
      </div>
    </header>

    <div class="script-container" data-display={defaultLang} data-pagefind-body>
      {availableLangs.length > 1 && (
        <div class="lang-toggle flex gap-1 mb-6 text-[12px] items-center">
          <span class="mr-2 text-[var(--color-ink-faint)]">显示</span>
          {availableLangs.map((lang) => (
            <button type="button" class="lang-btn px-2.5 py-1 rounded border border-[var(--color-rule)] text-[var(--color-ink-soft)] transition-colors" data-set-lang={lang}>
              {langLabel[lang] ?? lang}
            </button>
          ))}
          <button type="button" class="lang-btn px-2.5 py-1 rounded border border-[var(--color-rule)] text-[var(--color-ink-soft)] transition-colors" data-set-lang="both">双语</button>
        </div>
      )}

      <div id="view-mode" class="lines space-y-3">
        {lines.map((l) => (
          <SpeakerLine
            speaker={l.speaker}
            time={l.time}
            texts={l.texts}
            idx={speakerOrder.indexOf(l.speaker)}
          />
        ))}
      </div>

      {isDev && <div id="edit-mode" class="hidden"></div>}
    </div>

    {entry.data.sensitivity === 'high' && (
      <p class="mt-8 text-[12px]" style="color: var(--color-ink-faint)">
        本作品来源于版权敏感的赛事/电视节目。本站仅保留文字片段供研究学习，请通过原视频链接观看完整内容支持创作者。
      </p>
    )}

    {entry.data.ingestion && (
      <details class="mt-12 text-[12px]" style="color: var(--color-ink-faint)">
        <summary class="cursor-pointer hover:text-[var(--color-ink-soft)]">溯源信息</summary>
        <dl class="mt-3 grid grid-cols-[auto_1fr] gap-x-4 gap-y-1">
          {entry.data.source.fetched_at && <><dt>抓取时间</dt><dd class="tabular-nums">{entry.data.source.fetched_at}</dd></>}
          {entry.data.source.fetched_with && <><dt>抓取工具</dt><dd>{entry.data.source.fetched_with}</dd></>}
          {entry.data.ingestion.pipeline_version && <><dt>Pipeline</dt><dd>{entry.data.ingestion.pipeline_version}</dd></>}
          {entry.data.ingestion.asr && <><dt>ASR</dt><dd>{entry.data.ingestion.asr.backend} / {entry.data.ingestion.asr.model}</dd></>}
          {entry.data.ingestion.asr?.detected_language && <><dt>语言</dt><dd>{entry.data.ingestion.asr.detected_language}</dd></>}
          {entry.data.ingestion.asr?.word_count && <><dt>词数</dt><dd>{entry.data.ingestion.asr.word_count}</dd></>}
          {entry.data.ingestion.diarization && <><dt>分离</dt><dd>{entry.data.ingestion.diarization.model} ({entry.data.ingestion.diarization.num_speakers}人 / {entry.data.ingestion.diarization.turn_count}轮)</dd></>}
          {entry.data.contributed_by && <><dt>贡献者</dt><dd>{entry.data.contributed_by}</dd></>}
        </dl>
      </details>
    )}

    {isDev && (
      <div class="mt-10 pt-4 border-t" style="border-color: var(--color-rule)">
        <button id="delete-entry" type="button" class="text-[12px] underline" style="color: var(--color-warm)">
          删除此条目（本地）
        </button>
      </div>
    )}
  </article>

  {isDev && (
    <div id="edit-toolbar" class="hidden fixed bottom-0 left-0 right-0 border-t backdrop-blur" style="background-color: rgba(251, 249, 244, 0.95); border-color: var(--color-rule)">
      <div class="max-w-3xl mx-auto px-6 py-3 flex items-center gap-3 text-[13px]">
        <span id="edit-status" class="text-[var(--color-ink-faint)]">编辑中</span>
        <button id="edit-add-end" type="button" class="ml-auto px-2 py-1 border rounded" style="border-color: var(--color-rule)">+ 末尾添加</button>
        <button id="edit-cancel" type="button" class="px-2 py-1 border rounded" style="border-color: var(--color-rule)">取消</button>
        <button id="edit-save" type="button" class="px-3 py-1 border rounded font-medium" style="border-color: var(--color-ink); background-color: var(--color-ink); color: var(--color-bg)">保存</button>
      </div>
    </div>
  )}

  <script type="application/json" id="editor-bootstrap" set:html={JSON.stringify(editorBootstrap)}></script>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const container = btn.closest<HTMLElement>('.script-container');
        const lang = btn.dataset.setLang;
        if (container && lang) container.dataset.display = lang;
      });
    });

    // ----- Editor (dev-only) ----------------------------------------------

    type Utterance = {
      id: string;
      t: string;
      speaker: string;
      text: string;
      translations?: Record<string, string>;
    };
    type Bootstrap = {
      slug: string;
      utterances: Utterance[];
      speakerOptions: string[];
      sourceLang: string;
      dialoguePath: string;
      entryPath: string;
      githubEditDialogue: string;
    };

    const bootstrapEl = document.getElementById('editor-bootstrap');
    if (bootstrapEl) {
      const data: Bootstrap = JSON.parse(bootstrapEl.textContent || '{}');
      const enterBtn = document.getElementById('enter-edit') as HTMLButtonElement | null;
      const editMode = document.getElementById('edit-mode') as HTMLDivElement | null;
      const viewMode = document.getElementById('view-mode') as HTMLDivElement | null;
      const toolbar = document.getElementById('edit-toolbar') as HTMLDivElement | null;
      const statusEl = document.getElementById('edit-status');
      const addEndBtn = document.getElementById('edit-add-end');
      const cancelBtn = document.getElementById('edit-cancel');
      const saveBtn = document.getElementById('edit-save');
      const deleteBtn = document.getElementById('delete-entry');

      let working: Utterance[] = JSON.parse(JSON.stringify(data.utterances));
      let dirty = false;

      const setStatus = (msg: string) => { if (statusEl) statusEl.textContent = msg; };
      const markDirty = () => { dirty = true; setStatus('未保存改动'); };

      const newId = () => {
        const used = new Set(working.map((u) => u.id));
        for (let n = 1; ; n++) {
          const id = `u${n}`;
          if (!used.has(id)) return id;
        }
      };

      const render = () => {
        if (!editMode) return;
        editMode.innerHTML = '';
        working.forEach((u, i) => {
          const row = document.createElement('div');
          row.className = 'flex gap-2 py-1.5 items-start text-[14px]';
          row.dataset.idx = String(i);

          const ts = document.createElement('input');
          ts.type = 'text';
          ts.value = u.t;
          ts.className = 'w-20 text-[11px] tabular-nums px-1 py-0.5 border rounded bg-transparent';
          ts.style.borderColor = 'var(--color-rule)';
          ts.title = '时间戳 HH:MM:SS';
          ts.addEventListener('input', () => { working[i].t = ts.value; markDirty(); });

          const sp = document.createElement('select');
          sp.className = 'w-24 px-1 py-0.5 border rounded bg-transparent text-[13px]';
          sp.style.borderColor = 'var(--color-rule)';
          for (const opt of data.speakerOptions) {
            const o = document.createElement('option');
            o.value = opt; o.textContent = opt;
            if (opt === u.speaker) o.selected = true;
            sp.appendChild(o);
          }
          if (!data.speakerOptions.includes(u.speaker)) {
            const o = document.createElement('option');
            o.value = u.speaker; o.textContent = u.speaker; o.selected = true;
            sp.appendChild(o);
          }
          sp.addEventListener('change', () => { working[i].speaker = sp.value; markDirty(); });

          const tx = document.createElement('textarea');
          tx.value = u.text;
          tx.rows = 1;
          tx.className = 'flex-1 px-2 py-1 border rounded bg-transparent leading-relaxed';
          tx.style.borderColor = 'var(--color-rule)';
          tx.style.resize = 'vertical';
          tx.addEventListener('input', () => {
            working[i].text = tx.value;
            tx.style.height = 'auto';
            tx.style.height = tx.scrollHeight + 'px';
            markDirty();
          });
          // auto-grow on initial render
          requestAnimationFrame(() => {
            tx.style.height = 'auto';
            tx.style.height = tx.scrollHeight + 'px';
          });

          const btnBox = document.createElement('div');
          btnBox.className = 'flex flex-col gap-1';
          const mkBtn = (label: string, onClick: () => void, title: string) => {
            const b = document.createElement('button');
            b.type = 'button';
            b.textContent = label;
            b.title = title;
            b.className = 'w-7 h-6 text-[11px] border rounded';
            b.style.borderColor = 'var(--color-rule)';
            b.addEventListener('click', onClick);
            return b;
          };
          const addBelow = mkBtn('+', () => {
            working.splice(i + 1, 0, {
              id: newId(), t: u.t, speaker: u.speaker, text: '',
            });
            markDirty(); render();
          }, '在下方插入');
          const upBtn = mkBtn('↑', () => {
            if (i === 0) return;
            [working[i - 1], working[i]] = [working[i], working[i - 1]];
            markDirty(); render();
          }, '上移');
          const downBtn = mkBtn('↓', () => {
            if (i === working.length - 1) return;
            [working[i + 1], working[i]] = [working[i], working[i + 1]];
            markDirty(); render();
          }, '下移');
          const delBtn = mkBtn('×', () => {
            if (!confirm('删除这一行？')) return;
            working.splice(i, 1);
            markDirty(); render();
          }, '删除');

          btnBox.append(addBelow, upBtn, downBtn, delBtn);
          row.append(ts, sp, tx, btnBox);
          editMode.appendChild(row);
        });
      };

      const enterEdit = () => {
        if (!editMode || !viewMode || !toolbar) return;
        viewMode.classList.add('hidden');
        editMode.classList.remove('hidden');
        toolbar.classList.remove('hidden');
        document.body.style.paddingBottom = '80px';
        setStatus('编辑中');
        dirty = false;
        render();
      };

      const exitEdit = (force = false) => {
        if (dirty && !force && !confirm('有未保存改动，确定退出？')) return;
        if (!editMode || !viewMode || !toolbar) return;
        editMode.classList.add('hidden');
        viewMode.classList.remove('hidden');
        toolbar.classList.add('hidden');
        document.body.style.paddingBottom = '';
        working = JSON.parse(JSON.stringify(data.utterances));
        dirty = false;
      };

      const save = async () => {
        setStatus('保存中…');
        try {
          const r = await fetch(`/api/dev/dialogue/${encodeURIComponent(data.slug)}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ utterances: working }),
          });
          if (!r.ok) throw new Error(`HTTP ${r.status}: ${await r.text()}`);
          const json = await r.json();
          setStatus(`已保存 (${json.bytes ?? '?'} bytes)`);
          dirty = false;
          // Reload so server-rendered view picks up the new yaml.
          setTimeout(() => location.reload(), 400);
        } catch (e) {
          setStatus('保存失败');
          alert(`保存失败:\n${(e as Error).message}\n\n（dev API 仅在 \`npm run dev\` 时可用）`);
        }
      };

      const del = async () => {
        if (!confirm(`确定删除条目 "${data.slug}"？\n\n会删除：\n- ${data.entryPath}\n- ${data.dialoguePath}\n\n仅本地，需 git commit 后才推送。`)) return;
        try {
          const r = await fetch(`/api/dev/entry/${encodeURIComponent(data.slug)}`, { method: 'DELETE' });
          if (!r.ok) throw new Error(`HTTP ${r.status}: ${await r.text()}`);
          location.href = '/web/manzai/';
        } catch (e) {
          alert(`删除失败:\n${(e as Error).message}`);
        }
      };

      enterBtn?.addEventListener('click', enterEdit);
      cancelBtn?.addEventListener('click', () => exitEdit());
      saveBtn?.addEventListener('click', save);
      deleteBtn?.addEventListener('click', del);
      addEndBtn?.addEventListener('click', () => {
        const last = working[working.length - 1];
        working.push({
          id: newId(),
          t: last?.t ?? '00:00:00',
          speaker: last?.speaker ?? data.speakerOptions[0] ?? 'speaker',
          text: '',
        });
        markDirty(); render();
      });
    }
  </script>
</Base>
