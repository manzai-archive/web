---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SpeakerLine from '../../components/SpeakerLine.astro';

export async function getStaticPaths() {
  const entries = await getCollection('manzai');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;

const lineRegex = /\*\*(.+?)\*\*\s*\[(\d{2}:\d{2}:\d{2})\]\s*(.+)/;
const speakerMap: Record<string, string> = entry.data.speakers ?? {};
const sourceLang = entry.data.language;
const translations: Record<string, string[]> = entry.data.translations ?? {};

const bodyMatches = entry.body
  .split('\n')
  .map((l: string) => l.match(lineRegex))
  .filter((m: RegExpMatchArray | null): m is RegExpMatchArray => m !== null);

const validTranslations: Record<string, string[]> = {};
for (const [lang, arr] of Object.entries(translations)) {
  if (Array.isArray(arr) && arr.length === bodyMatches.length) {
    validTranslations[lang] = arr;
  }
}

const availableLangs = [sourceLang, ...Object.keys(validTranslations).filter((l) => l !== sourceLang)];
const defaultLang = availableLangs.includes('zh') ? 'zh' : sourceLang;

const lines = bodyMatches.map((m, i) => {
  const texts: Record<string, string> = { [sourceLang]: m[3] };
  for (const [lang, arr] of Object.entries(validTranslations)) {
    texts[lang] = arr[i];
  }
  return {
    speaker: speakerMap[m[1]] ?? m[1],
    time: m[2],
    texts,
  };
});

const speakerOrder = Array.from(new Set(lines.map((l) => l.speaker)));

const langLabel: Record<string, string> = { zh: '中', ja: '原文(日)', en: 'EN' };
---
<Base title={`${entry.data.title} · 漫才档案`}>
  <article>
    <div class="mb-6">
      <div class="text-xs text-neutral-500 mb-1" lang={sourceLang}>{entry.data.performers[0]?.name}</div>
      <h1 class="text-2xl font-bold mb-2" lang={sourceLang}>{entry.data.title}</h1>
      <div class="flex gap-1.5 text-xs flex-wrap mb-3">
        {entry.data.tags.map((t: string) => (
          <span class="px-2 py-0.5 bg-neutral-100 rounded">{t}</span>
        ))}
        {entry.data.status === 'draft' && (
          <span class="px-2 py-0.5 bg-amber-100 text-amber-700 rounded">draft (未校对)</span>
        )}
      </div>
      <div class="text-sm">
        <a class="underline text-blue-700" href={entry.data.source.url} target="_blank" rel="noopener">
          原视频 ({entry.data.source.platform})
        </a>
        {entry.data.source.uploader && (
          <span class="text-neutral-500"> · {entry.data.source.uploader}</span>
        )}
        {entry.data.source.uploaded_at && (
          <span class="text-neutral-500"> · {entry.data.source.uploaded_at}</span>
        )}
      </div>
    </div>

    <div class="script-container bg-white border border-neutral-200 rounded-md p-5" data-display={defaultLang} data-pagefind-body>
      {availableLangs.length > 1 && (
        <div class="lang-toggle flex gap-1 mb-4 text-sm items-center">
          <span class="text-xs text-neutral-500 mr-2">显示</span>
          {availableLangs.map((lang) => (
            <button type="button" class="lang-btn px-3 py-1 rounded border border-neutral-300 hover:border-neutral-500" data-set-lang={lang}>
              {langLabel[lang] ?? lang}
            </button>
          ))}
          <button type="button" class="lang-btn px-3 py-1 rounded border border-neutral-300 hover:border-neutral-500" data-set-lang="both">双语</button>
        </div>
      )}

      <div class="lines">
        {lines.map((l) => (
          <SpeakerLine
            speaker={l.speaker}
            time={l.time}
            texts={l.texts}
            idx={speakerOrder.indexOf(l.speaker)}
          />
        ))}
      </div>
    </div>

    {entry.data.sensitivity === 'high' && (
      <p class="mt-4 text-xs text-neutral-500">
        本作品来源于版权敏感的赛事/电视节目。本站仅保留文字片段供研究学习，请通过原视频链接观看完整内容支持创作者。
      </p>
    )}
  </article>

  <script>
    document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const container = btn.closest<HTMLElement>('.script-container');
        const lang = btn.dataset.setLang;
        if (container && lang) container.dataset.display = lang;
      });
    });
  </script>
</Base>
