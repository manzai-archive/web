---
import { getCollection, getEntry } from 'astro:content';
import Base from '../../layouts/Base.astro';
import SpeakerLine from '../../components/SpeakerLine.astro';

export async function getStaticPaths() {
  const entries = await getCollection('manzai');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;

const speakerMap: Record<string, string> = entry.data.speakers ?? {};
const sourceLang = entry.data.language;

const dialogueEntry = await getEntry('dialogues', entry.id);

type RawUtterance = { id: string; t: string; speaker: string; text: string; translations?: Record<string, string> };
type Utterance = { id: string; speaker: string; time: string; texts: Record<string, string> };

let rawUtterances: RawUtterance[] = [];
let lines: Utterance[] = [];

if (dialogueEntry) {
  rawUtterances = dialogueEntry.data.utterances.map((u, i) => ({
    id: u.id || `u${i + 1}`,
    t: u.t,
    speaker: u.speaker,
    text: u.text,
    translations: u.translations,
  }));
  for (const u of rawUtterances) {
    const texts: Record<string, string> = { [sourceLang]: u.text };
    for (const [lang, t] of Object.entries(u.translations ?? {})) {
      if (typeof t === 'string') texts[lang] = t;
    }
    lines.push({ id: u.id, speaker: speakerMap[u.speaker] ?? u.speaker, time: u.t, texts });
  }
} else {
  // Legacy in-body parsing (pre-Plan-C entries)
  const lineRegex = /\*\*(.+?)\*\*\s*\[(\d{2}:\d{2}:\d{2})\]\s*(.+)/;
  const bodyMatches = entry.body.split('\n')
    .map((l: string) => l.match(lineRegex))
    .filter((m: RegExpMatchArray | null): m is RegExpMatchArray => m !== null);
  rawUtterances = bodyMatches.map((m, i) => ({ id: `u${i + 1}`, t: m[2], speaker: m[1], text: m[3] }));
  lines = bodyMatches.map((m, i) => ({
    id: `u${i + 1}`,
    speaker: speakerMap[m[1]] ?? m[1],
    time: m[2],
    texts: { [sourceLang]: m[3] },
  }));
}

const availableLangs = Array.from(new Set(lines.flatMap((l) => Object.keys(l.texts))))
  .sort((a, b) => (a === sourceLang ? -1 : b === sourceLang ? 1 : 0));
const defaultLang = availableLangs.includes('zh') ? 'zh' : sourceLang;

const FORM_LABEL: Record<string, string> = {
  manzai: '漫才', xiangsheng: '相声', standup: '脱口秀',
  sketch: 'コント / 小品', rakugo: '落語', other: '其他',
};
const formLabel = FORM_LABEL[entry.data.form] ?? entry.data.form;
const roles: Record<string, string> = entry.data.roles ?? {};

const speakerOrder = Array.from(new Set(lines.map((l) => l.speaker)));

const langLabel: Record<string, string> = { zh: '中', ja: '日', en: 'EN', auto: '原文' };

const perfRef = entry.data.performers[0];
const perf = perfRef ? await getEntry(perfRef) : null;
const perfName = perf?.data.display_name ?? (typeof perfRef === 'string' ? perfRef : perfRef?.id) ?? 'Unknown';
const perfLang = perf?.data.language ?? sourceLang;

const memberNames = (perf?.data.members ?? []).map((m: { name: string }) => m.name);
const speakerOptions = Array.from(new Set([...memberNames, ...rawUtterances.map((u) => u.speaker)])).filter(Boolean);

const isDev = import.meta.env.DEV;
const dialoguePath = `src/content/dialogues/${entry.id}.yaml`;
const entryPath = `src/content/manzai/${entry.id}.md`;
const githubBase = 'https://github.com/manzai-archive/web';
const githubEditDialogue = `${githubBase}/edit/main/${dialoguePath}`;

const editorBootstrap = {
  slug: entry.id,
  utterances: rawUtterances,
  speakerOptions,
  sourceLang,
  dialoguePath,
  entryPath,
};
---
<Base title={`${entry.data.title} · 喜剧档案`}>
  <article>
    <header class="mb-10">
      <div class="flex items-baseline gap-3 text-[12px] mb-3" style="color: var(--color-ink-faint)">
        <span class="px-1.5 py-0.5 border rounded text-[11px] tracking-wide" style="border-color: var(--color-rule); color: var(--color-ink-soft)">{formLabel}</span>
        <span lang={perfLang} class="text-[var(--color-ink-soft)]">{perfName}</span>
        {entry.data.source.uploaded_at && (
          <span class="ml-auto tabular-nums">{entry.data.source.uploaded_at}</span>
        )}
      </div>

      <h1 class="text-3xl leading-tight mb-5" lang={sourceLang}>{entry.data.title}</h1>

      {Object.keys(roles).length > 0 && (
        <div class="text-[13px] mb-3" lang={perfLang}>
          {Object.entries(roles).map(([name, role]: [string, string], i: number) => (
            <>
              {i > 0 && <span class="mx-2" style="color: var(--color-ink-faint)">·</span>}
              <span class="font-medium">{name}</span>
              <span class="ml-1.5" style="color: var(--color-ink-faint)">{role}</span>
            </>
          ))}
        </div>
      )}

      <div class="flex flex-wrap items-center gap-3 text-[12px]" style="color: var(--color-ink-faint)">
        <a class="underline hover:text-[var(--color-ink-soft)]" href={entry.data.source.url} target="_blank" rel="noopener">
          原视频 ({entry.data.source.platform})
        </a>
        {entry.data.source.uploader && <span>{entry.data.source.uploader}</span>}
        {entry.data.tags.map((t: string) => <span>#{t}</span>)}
        {entry.data.status === 'draft' && <span style="color: var(--color-warm)">未校对</span>}
        <a class="ml-auto underline hover:text-[var(--color-ink-soft)]" href={githubEditDialogue} target="_blank" rel="noopener">
          在 GitHub 上编辑
        </a>
        {isDev && (
          <button id="enter-edit" type="button" class="px-2 py-0.5 border rounded text-[11px]" style="border-color: var(--color-rule); color: var(--color-ink-soft)">
            编辑
          </button>
        )}
      </div>
    </header>

    <div id="script-container" class="script-container" data-display={defaultLang} data-pagefind-body>
      {availableLangs.length > 1 && (
        <div class="lang-toggle flex gap-1 mb-6 text-[12px] items-center">
          <span class="mr-2 text-[var(--color-ink-faint)]">显示</span>
          {availableLangs.map((lang) => (
            <button type="button" class="lang-btn px-2.5 py-1 rounded border border-[var(--color-rule)] text-[var(--color-ink-soft)] transition-colors" data-set-lang={lang}>
              {langLabel[lang] ?? lang}
            </button>
          ))}
          <button type="button" class="lang-btn px-2.5 py-1 rounded border border-[var(--color-rule)] text-[var(--color-ink-soft)] transition-colors" data-set-lang="both">双语</button>
        </div>
      )}

      <div id="lines" class="lines space-y-3">
        {lines.map((l, i) => (
          <SpeakerLine
            speaker={l.speaker}
            time={l.time}
            texts={l.texts}
            idx={speakerOrder.indexOf(l.speaker)}
            uid={l.id}
          />
        ))}
      </div>
    </div>

    {entry.data.sensitivity === 'high' && (
      <p class="mt-8 text-[12px]" style="color: var(--color-ink-faint)">
        本作品来源于版权敏感的赛事/电视节目。本站仅保留文字片段供研究学习，请通过原视频链接观看完整内容支持创作者。
      </p>
    )}

    {entry.data.ingestion && (
      <details class="mt-12 text-[12px]" style="color: var(--color-ink-faint)">
        <summary class="cursor-pointer hover:text-[var(--color-ink-soft)]">溯源信息</summary>
        <dl class="mt-3 grid grid-cols-[auto_1fr] gap-x-4 gap-y-1">
          {entry.data.source.fetched_at && <><dt>抓取时间</dt><dd class="tabular-nums">{entry.data.source.fetched_at}</dd></>}
          {entry.data.source.fetched_with && <><dt>抓取工具</dt><dd>{entry.data.source.fetched_with}</dd></>}
          {entry.data.ingestion.pipeline_version && <><dt>Pipeline</dt><dd>{entry.data.ingestion.pipeline_version}</dd></>}
          {entry.data.ingestion.asr && <><dt>ASR</dt><dd>{entry.data.ingestion.asr.backend} / {entry.data.ingestion.asr.model}</dd></>}
          {entry.data.ingestion.asr?.detected_language && <><dt>语言</dt><dd>{entry.data.ingestion.asr.detected_language}</dd></>}
          {entry.data.ingestion.asr?.word_count && <><dt>词数</dt><dd>{entry.data.ingestion.asr.word_count}</dd></>}
          {entry.data.ingestion.diarization && <><dt>分离</dt><dd>{entry.data.ingestion.diarization.model} ({entry.data.ingestion.diarization.num_speakers}人 / {entry.data.ingestion.diarization.turn_count}轮)</dd></>}
          {entry.data.contributed_by && <><dt>贡献者</dt><dd>{entry.data.contributed_by}</dd></>}
        </dl>
      </details>
    )}
  </article>

  {isDev && (
    <>
      <!-- floating toolbar -->
      <div id="edit-toolbar" class="hidden fixed bottom-0 left-0 right-0 border-t backdrop-blur z-20" style="background-color: rgba(251, 249, 244, 0.94); border-color: var(--color-rule)">
        <div class="max-w-3xl mx-auto px-6 py-3 flex items-center gap-3 text-[13px]">
          <span class="text-[var(--color-ink-faint)]">编辑模式</span>
          <span id="edit-status" class="text-[var(--color-ink-faint)]">·</span>
          <span class="ml-auto text-[11px] text-[var(--color-ink-faint)]">点说话人切换 · 点文字编辑 · 行末 ⋮ 增删换序</span>
          <button id="edit-delete" type="button" class="px-2 py-1 border rounded text-[11px]" style="border-color: var(--color-rule); color: var(--color-warm)">删除整条</button>
          <button id="edit-cancel" type="button" class="px-3 py-1 border rounded" style="border-color: var(--color-rule)">取消</button>
          <button id="edit-save" type="button" class="px-3 py-1 border rounded font-medium" style="border-color: var(--color-ink); background-color: var(--color-ink); color: var(--color-bg)">保存</button>
        </div>
      </div>

      <!-- row action menu (popover) -->
      <div id="row-menu" class="hidden fixed z-30 border bg-[var(--color-bg)] rounded shadow-sm text-[12px]" style="border-color: var(--color-rule); min-width: 140px">
        <button data-action="add-above" class="block w-full text-left px-3 py-1.5 hover:bg-black/5">↑ 上方插入</button>
        <button data-action="add-below" class="block w-full text-left px-3 py-1.5 hover:bg-black/5">↓ 下方插入</button>
        <button data-action="up" class="block w-full text-left px-3 py-1.5 hover:bg-black/5">↑ 上移</button>
        <button data-action="down" class="block w-full text-left px-3 py-1.5 hover:bg-black/5">↓ 下移</button>
        <button data-action="del" class="block w-full text-left px-3 py-1.5 hover:bg-black/5" style="color: var(--color-warm)">× 删除此行</button>
      </div>

      <!-- speaker picker popover -->
      <div id="speaker-pop" class="hidden fixed z-30 border bg-[var(--color-bg)] rounded shadow-sm text-[13px]" style="border-color: var(--color-rule); min-width: 100px"></div>
    </>
  )}

  <script type="application/json" id="editor-bootstrap" set:html={JSON.stringify(editorBootstrap)}></script>

  <style>
    .lines.editing .script-line {
      border-left: 2px solid transparent;
      padding-left: 8px;
      margin-left: -10px;
      transition: border-color 0.15s, background-color 0.15s;
    }
    .lines.editing .script-line:hover {
      border-left-color: var(--color-rule);
      background-color: rgba(0,0,0,0.015);
    }
    .lines.editing .script-line.dirty {
      border-left-color: var(--color-warm);
    }
    .lines.editing [data-role="speaker"] {
      cursor: pointer;
      border-bottom: 1px dashed transparent;
    }
    .lines.editing [data-role="speaker"]:hover {
      border-bottom-color: var(--color-ink-faint);
    }
    .lines.editing [data-role="text"] {
      cursor: text;
      outline: none;
      border-radius: 2px;
    }
    .lines.editing [data-role="text"]:focus {
      background-color: rgba(255, 220, 130, 0.18);
    }
    .row-menu-trigger {
      position: absolute;
      right: -8px;
      top: 4px;
      width: 22px;
      height: 22px;
      display: none;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      color: var(--color-ink-faint);
      font-size: 14px;
      border-radius: 3px;
    }
    .row-menu-trigger:hover {
      background-color: rgba(0,0,0,0.06);
      color: var(--color-ink);
    }
    .lines.editing .script-line:hover .row-menu-trigger {
      display: flex;
    }
    .lines.editing .script-line .row-menu-trigger.pinned {
      display: flex;
    }
  </style>

  <script>
    // language toggle (always on)
    document.querySelectorAll<HTMLButtonElement>('.lang-btn').forEach((btn) => {
      btn.addEventListener('click', () => {
        const container = btn.closest<HTMLElement>('.script-container');
        const lang = btn.dataset.setLang;
        if (container && lang) container.dataset.display = lang;
      });
    });

    // ====== Editor (dev-only) ===========================================

    type Utt = { id: string; t: string; speaker: string; text: string; translations?: Record<string, string> };
    type Boot = { slug: string; utterances: Utt[]; speakerOptions: string[]; sourceLang: string; dialoguePath: string; entryPath: string };

    const bootEl = document.getElementById('editor-bootstrap');
    if (bootEl) {
      const boot: Boot = JSON.parse(bootEl.textContent || '{}');
      const linesEl = document.getElementById('lines') as HTMLElement | null;
      const enterBtn = document.getElementById('enter-edit') as HTMLButtonElement | null;
      const toolbar = document.getElementById('edit-toolbar') as HTMLElement | null;
      const statusEl = document.getElementById('edit-status') as HTMLElement | null;
      const cancelBtn = document.getElementById('edit-cancel');
      const saveBtn = document.getElementById('edit-save');
      const deleteEntryBtn = document.getElementById('edit-delete');
      const rowMenu = document.getElementById('row-menu') as HTMLElement | null;
      const speakerPop = document.getElementById('speaker-pop') as HTMLElement | null;

      // working copy keyed by id
      let working: Utt[] = JSON.parse(JSON.stringify(boot.utterances));
      let editing = false;
      let dirty = false;

      const setStatus = (s: string) => { if (statusEl) statusEl.textContent = s; };

      const findIdx = (id: string) => working.findIndex((u) => u.id === id);

      const newId = () => {
        const used = new Set(working.map((u) => u.id));
        for (let n = 1; ; n++) { const id = `u${n}`; if (!used.has(id)) return id; }
      };

      const markDirty = () => {
        const changed = JSON.stringify(working) !== JSON.stringify(boot.utterances);
        dirty = changed;
        setStatus(changed ? '有未保存改动' : '·');
      };

      // ----- in-place rendering -----
      const renderLineDom = (u: Utt) => {
        const row = linesEl?.querySelector(`.script-line[data-uid="${cssEscape(u.id)}"]`) as HTMLElement | null;
        if (!row) return;
        const speakerEl = row.querySelector('[data-role="speaker"]') as HTMLElement | null;
        const textEl = row.querySelector('[data-role="text"]') as HTMLElement | null;
        const timeEl = row.querySelector('[data-role="time"]') as HTMLElement | null;
        if (speakerEl) speakerEl.textContent = u.speaker;
        if (textEl) {
          const langSpans = Array.from(textEl.querySelectorAll<HTMLElement>('[lang]'));
          const sourceSpan = langSpans.find((s) => s.lang === boot.sourceLang) || langSpans[0];
          if (sourceSpan) sourceSpan.textContent = u.text;
        }
        if (timeEl) timeEl.textContent = u.t;
        if (JSON.stringify(u) !== JSON.stringify(boot.utterances[findIdxOriginal(u.id)] ?? null)) {
          row.classList.add('dirty');
        } else {
          row.classList.remove('dirty');
        }
      };

      const findIdxOriginal = (id: string) => boot.utterances.findIndex((u) => u.id === id);

      const cssEscape = (s: string) => (window as any).CSS?.escape ? (window as any).CSS.escape(s) : s.replace(/[^a-zA-Z0-9_-]/g, (c) => `\\${c}`);

      const buildRowFor = (u: Utt, idx: number): HTMLElement => {
        const tpl = document.createElement('div');
        const sourceSpanLang = boot.sourceLang;
        tpl.innerHTML = `
          <div class="script-line group relative flex gap-4 py-1" data-uid="${escAttr(u.id)}" data-speaker-idx="${idx % 2}">
            <span class="speaker shrink-0 w-20 text-right text-[13px] font-medium" style="line-height: 1.85" data-role="speaker">${escHtml(u.speaker)}</span>
            <span class="text-[11px] tabular-nums shrink-0 w-14 pt-1" style="color: var(--color-ink-faint)" data-role="time">${escHtml(u.t)}</span>
            <span class="flex-1 line-text text-[15px] leading-[1.85]" data-role="text">
              <span class="text-${sourceSpanLang}" lang="${sourceSpanLang}">${escHtml(u.text)}</span>
            </span>
            <span class="row-menu-trigger" title="行操作">⋮</span>
          </div>
        `;
        return tpl.firstElementChild as HTMLElement;
      };

      const escHtml = (s: string) => s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' } as any)[c]);
      const escAttr = (s: string) => escHtml(s);

      // attach editor handlers to a single .script-line
      const wireRow = (row: HTMLElement) => {
        const uid = row.dataset.uid!;
        const speakerEl = row.querySelector('[data-role="speaker"]') as HTMLElement | null;
        const textEl = row.querySelector('[data-role="text"]') as HTMLElement | null;
        let trigger = row.querySelector('.row-menu-trigger') as HTMLElement | null;
        if (!trigger) {
          trigger = document.createElement('span');
          trigger.className = 'row-menu-trigger';
          trigger.textContent = '⋮';
          trigger.title = '行操作';
          row.appendChild(trigger);
        }
        speakerEl?.addEventListener('click', (e) => {
          e.stopPropagation();
          openSpeakerPicker(uid, speakerEl);
        });
        if (textEl) {
          textEl.contentEditable = 'true';
          textEl.spellcheck = false;
          textEl.addEventListener('input', () => {
            const idx = findIdx(uid);
            if (idx >= 0) {
              // Pull source-lang span text only
              const sourceSpan = textEl.querySelector(`[lang="${boot.sourceLang}"]`) as HTMLElement | null;
              const newText = (sourceSpan?.textContent ?? textEl.textContent ?? '').replace(/\s+$/, '');
              working[idx].text = newText;
              row.classList.add('dirty');
              markDirty();
            }
          });
        }
        trigger?.addEventListener('click', (e) => {
          e.stopPropagation();
          openRowMenu(uid, trigger as HTMLElement);
        });
      };

      // ----- speaker picker popover -----
      let pickerForUid: string | null = null;
      const openSpeakerPicker = (uid: string, anchor: HTMLElement) => {
        if (!speakerPop) return;
        pickerForUid = uid;
        speakerPop.innerHTML = '';
        for (const opt of boot.speakerOptions) {
          const b = document.createElement('button');
          b.type = 'button';
          b.textContent = opt;
          b.className = 'block w-full text-left px-3 py-1.5 hover:bg-black/5';
          b.addEventListener('click', () => {
            const idx = findIdx(uid);
            if (idx >= 0) {
              working[idx].speaker = opt;
              const row = linesEl?.querySelector(`.script-line[data-uid="${cssEscape(uid)}"]`) as HTMLElement | null;
              const speakerEl = row?.querySelector('[data-role="speaker"]') as HTMLElement | null;
              if (speakerEl) speakerEl.textContent = opt;
              row?.classList.add('dirty');
              markDirty();
            }
            closePopups();
          });
          speakerPop.appendChild(b);
        }
        const r = anchor.getBoundingClientRect();
        speakerPop.style.left = `${r.left}px`;
        speakerPop.style.top = `${r.bottom + 4}px`;
        speakerPop.classList.remove('hidden');
      };

      // ----- row menu popover -----
      let menuForUid: string | null = null;
      let menuTrigger: HTMLElement | null = null;
      const openRowMenu = (uid: string, anchor: HTMLElement) => {
        if (!rowMenu) return;
        menuForUid = uid;
        menuTrigger?.classList.remove('pinned');
        menuTrigger = anchor;
        anchor.classList.add('pinned');
        const r = anchor.getBoundingClientRect();
        rowMenu.style.left = `${Math.min(r.left, window.innerWidth - 160)}px`;
        rowMenu.style.top = `${r.bottom + 4}px`;
        rowMenu.classList.remove('hidden');
      };

      rowMenu?.querySelectorAll<HTMLButtonElement>('button[data-action]').forEach((b) => {
        b.addEventListener('click', () => {
          if (!menuForUid) return;
          const action = b.dataset.action;
          const uid = menuForUid;
          handleRowAction(action!, uid);
          closePopups();
        });
      });

      const handleRowAction = (action: string, uid: string) => {
        const idx = findIdx(uid);
        if (idx < 0) return;
        if (action === 'add-above' || action === 'add-below') {
          const cur = working[idx];
          const insertAt = action === 'add-above' ? idx : idx + 1;
          const fresh: Utt = {
            id: newId(),
            t: cur.t,
            speaker: cur.speaker,
            text: '',
          };
          working.splice(insertAt, 0, fresh);
          // insert DOM
          const newRow = buildRowFor(fresh, insertAt);
          const curRow = linesEl?.querySelector(`.script-line[data-uid="${cssEscape(uid)}"]`) as HTMLElement | null;
          if (curRow && linesEl) {
            if (action === 'add-above') curRow.before(newRow);
            else curRow.after(newRow);
            wireRow(newRow);
            (newRow.querySelector('[data-role="text"]') as HTMLElement | null)?.focus();
          }
          markDirty();
        } else if (action === 'up' || action === 'down') {
          const swap = action === 'up' ? idx - 1 : idx + 1;
          if (swap < 0 || swap >= working.length) return;
          [working[idx], working[swap]] = [working[swap], working[idx]];
          // swap DOM
          const a = linesEl?.querySelector(`.script-line[data-uid="${cssEscape(working[idx].id)}"]`) as HTMLElement | null;
          const b = linesEl?.querySelector(`.script-line[data-uid="${cssEscape(working[swap].id)}"]`) as HTMLElement | null;
          if (a && b && linesEl) {
            if (action === 'up') a.before(b);
            else a.after(b);
          }
          markDirty();
        } else if (action === 'del') {
          if (!confirm('删除这一行？')) return;
          working.splice(idx, 1);
          const row = linesEl?.querySelector(`.script-line[data-uid="${cssEscape(uid)}"]`) as HTMLElement | null;
          row?.remove();
          markDirty();
        }
      };

      const closePopups = () => {
        rowMenu?.classList.add('hidden');
        speakerPop?.classList.add('hidden');
        menuTrigger?.classList.remove('pinned');
        menuTrigger = null;
        menuForUid = null;
        pickerForUid = null;
      };
      document.addEventListener('click', (e) => {
        if (rowMenu && !rowMenu.contains(e.target as Node) && speakerPop && !speakerPop.contains(e.target as Node)) {
          closePopups();
        }
      });
      window.addEventListener('scroll', closePopups, true);
      window.addEventListener('resize', closePopups);

      // ----- enter / exit edit mode -----
      const enterEdit = () => {
        if (!linesEl || !toolbar) return;
        editing = true;
        linesEl.classList.add('editing');
        toolbar.classList.remove('hidden');
        document.body.style.paddingBottom = '64px';
        setStatus('·');
        // wire each existing row
        linesEl.querySelectorAll<HTMLElement>('.script-line').forEach(wireRow);
      };

      const exitEdit = (force = false) => {
        if (dirty && !force && !confirm('有未保存改动，确定退出？')) return;
        location.reload(); // simplest: reload to discard any DOM mess
      };

      const save = async () => {
        setStatus('保存中…');
        try {
          const r = await fetch(`/api/dev/dialogue/${encodeURIComponent(boot.slug)}`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ utterances: working }),
          });
          if (!r.ok) throw new Error(`HTTP ${r.status}: ${await r.text()}`);
          setStatus('已保存，刷新中…');
          setTimeout(() => location.reload(), 300);
        } catch (e) {
          setStatus('保存失败');
          alert(`保存失败:\n${(e as Error).message}\n\n（dev API 仅在 npm run dev 模式下可用）`);
        }
      };

      const deleteEntry = async () => {
        if (!confirm(`确定删除整个条目？\n\n会删除：\n- ${boot.entryPath}\n- ${boot.dialoguePath}`)) return;
        try {
          const r = await fetch(`/api/dev/entry/${encodeURIComponent(boot.slug)}`, { method: 'DELETE' });
          if (!r.ok) throw new Error(`HTTP ${r.status}: ${await r.text()}`);
          location.href = '/web/manzai/';
        } catch (e) {
          alert(`删除失败:\n${(e as Error).message}`);
        }
      };

      enterBtn?.addEventListener('click', enterEdit);
      cancelBtn?.addEventListener('click', () => exitEdit());
      saveBtn?.addEventListener('click', save);
      deleteEntryBtn?.addEventListener('click', deleteEntry);
    }
  </script>
</Base>
