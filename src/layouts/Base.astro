---
import '../styles/global.css';
const { title = '喜剧档案' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content="带说话人标注的口语喜剧剧本档案 · 漫才 / 相声 / 单口 / コント · 面向语言学习与喜剧研究 · 非营利" />
    <meta name="theme-color" content="#fbf9f4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1c1a17" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    {/* Inline pre-paint init: avoid light-flash on first load. Reads
        localStorage 'theme' (user choice) or falls back to system pref. */}
    <script is:inline>
      (function () {
        try {
          var stored = localStorage.getItem('theme');
          var sys = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
          var theme = stored || (sys ? 'dark' : 'light');
          document.documentElement.dataset.theme = theme;
        } catch (e) {
          document.documentElement.dataset.theme = 'light';
        }
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b" style="border-color: var(--color-rule)">
      <nav class="max-w-3xl mx-auto px-6 py-5 flex items-center justify-between">
        <a href={base} class="flex items-center gap-2.5 group">
          <img src={`${base}favicon.svg`} alt="" class="w-7 h-7" width="28" height="28" />
          <span class="text-base font-medium tracking-wide">喜剧档案</span>
        </a>
        <div class="flex items-center gap-5 text-[13px]" style="color: var(--color-ink-soft)">
          <a href={`${base}manzai/`} class="hover:text-[var(--color-ink)] transition-colors">剧本</a>
          <a href={`${base}contribute/`} class="hover:text-[var(--color-ink)] transition-colors">贡献</a>
          <a href={`${base}about/`} class="hover:text-[var(--color-ink)] transition-colors">关于</a>
          <a href="https://github.com/manzai-archive" class="hover:text-[var(--color-ink)] transition-colors" target="_blank" rel="noopener">GitHub</a>
          <button id="theme-toggle" type="button" class="theme-toggle w-7 h-7 inline-flex items-center justify-center rounded transition-colors hover:text-[var(--color-ink)]" aria-label="切换深浅色" title="切换深浅色">
            <svg class="theme-icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="4"></circle>
              <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"></path>
            </svg>
            <svg class="theme-icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <main class="flex-1 max-w-3xl w-full mx-auto px-6 py-12">
      <slot />
    </main>

    <footer class="border-t mt-20" style="border-color: var(--color-rule)">
      <div class="max-w-3xl mx-auto px-6 py-8 text-[12px] space-y-1.5" style="color: var(--color-ink-faint)">
        <div>非营利学习档案 · 原作版权归原作者及播出方所有 ·
          <a class="underline hover:text-[var(--color-ink-soft)]" href="https://github.com/manzai-archive/web/blob/main/NOTICE.md" target="_blank" rel="noopener">下架申请</a>
        </div>
        <div>
          维护： <a class="underline hover:text-[var(--color-ink-soft)]" href="https://github.com/enkerewpo" target="_blank" rel="noopener">wheatfox</a>
        </div>
      </div>
    </footer>

    <script>
      const btn = document.getElementById('theme-toggle');
      btn?.addEventListener('click', () => {
        const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('theme', next); } catch (e) { /* ignore */ }
      });
    </script>
  </body>
</html>
