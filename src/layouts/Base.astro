---
import '../styles/global.css';
const { title = '漫才アーカイブ' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content="話者ラベル付き漫才台本コーパス · 語学学習・お笑い研究のための非営利アーカイブ" />
  </head>
  <body class="bg-neutral-50 text-neutral-900 min-h-screen flex flex-col">
    <header class="border-b border-neutral-200 bg-white">
      <nav class="max-w-4xl mx-auto px-4 py-3 flex items-center justify-between text-sm">
        <a href={base} class="font-bold">漫才アーカイブ</a>
        <div class="flex gap-5">
          <a href={`${base}manzai/`} class="hover:underline">剧本</a>
          <a href={`${base}about/`} class="hover:underline">关于</a>
          <a href="https://github.com/manzai-archive" class="hover:underline" target="_blank" rel="noopener">GitHub</a>
        </div>
      </nav>
    </header>
    <main class="flex-1 max-w-4xl w-full mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="max-w-4xl w-full mx-auto px-4 py-6 mt-12 text-xs text-neutral-500 border-t border-neutral-200">
      非营利学习档案 · 原作著作权归原作者及播出方所有 ·
      <a class="underline" href="https://github.com/manzai-archive/web/blob/main/NOTICE.md" target="_blank" rel="noopener">下架申请</a>
    </footer>
  </body>
</html>
